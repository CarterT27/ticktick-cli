# TickTick CLI environment configuration

# Shared defaults used when unset
TICKTICK_CLIENT_ID=Ul8jc7U2kv5DwjN6Uw

# Optional (defaults to http://localhost:8080/callback)
TICKTICK_REDIRECT_URI=http://localhost:8080/callback

# Option A: BYO TickTick app credentials
# Set your own client ID alongside this if you are not using the shared broker.
TICKTICK_CLIENT_SECRET=

# Option B: Shared OAuth broker
# If TICKTICK_CLIENT_SECRET is unset, the CLI defaults to this broker URL.
TICKTICK_OAUTH_BROKER_URL=https://ticktick-auth-broker.carter-tran.workers.dev
# Optional broker header key (not used by the shared broker)
TICKTICK_OAUTH_BROKER_KEY=
